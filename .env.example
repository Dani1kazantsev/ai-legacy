TELEGRAM_BOT_TOKEN=your_token_from_botfather
OWNER_TELEGRAM_USER_ID=123456789

# OpenAI-compatible LLM provider. Default config is Groq (free tier, accessible from Russia).
# To switch provider, change base_url and api_key. Tested values:
#   Groq:        base_url=https://api.groq.com/openai/v1, model=llama-3.3-70b-versatile
#   Together AI: base_url=https://api.together.xyz/v1
#   OpenAI:      base_url=https://api.openai.com/v1, model=gpt-4o
#   Ollama:      base_url=http://localhost:11434/v1, api_key=ollama, model=qwen2.5:14b
LLM_API_KEY=gsk_your_groq_key_here
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1
